# HRAssistant-Agent — environment configuration
# Copy to .env and fill in your key. Never commit .env.

# Required: get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: force a single model instead of the default fallback list
# (default order: deepseek/deepseek-chat, meta-llama/llama-3.3-70b-instruct, qwen/qwen3-32b)
# OPENROUTER_MODEL=deepseek/deepseek-chat

# Optional tuning
# TEMPERATURE=0.3
# MAX_TOKENS=1024
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# RETRIEVAL_K=4
